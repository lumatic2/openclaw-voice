<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "$HOME/projects/ptt-voice-app/bridge" &amp;&amp; ./start.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>$HOME/projects/ptt-voice-app/bridge</string>
  <key>StandardOutPath</key>
  <string>/tmp/ai.openclaw.bridge.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/ai.openclaw.bridge.err.log</string>
</dict>
</plist>